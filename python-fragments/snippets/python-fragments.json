{
  "Fragment Block": {
    "prefix": "frag",
    "body": [
      "<>",
      "\t$0",
      "</>"
    ],
    "description": "Create a fragment block"
  },
  "HTML Element": {
    "prefix": "elem",
    "body": [
      "<${1:div}>",
      "\t$0",
      "</${1:div}>"
    ],
    "description": "Create an HTML element"
  },
  "Interpolation": {
    "prefix": "var",
    "body": [
      "{{ ${1:variable} }}"
    ],
    "description": "Insert an interpolation"
  },
  "Fragment For Loop": {
    "prefix": "for",
    "body": [
      "{% for ${1:item} in ${2:items} %}",
      "\t$0",
      "{% endfor %}"
    ],
    "description": "Create a fragment for loop"
  },
  "Fragment If Statement": {
    "prefix": "if",
    "body": [
      "{% if ${1:condition} %}",
      "\t$0",
      "{% endif %}"
    ],
    "description": "Create a fragment if statement"
  },
  "Fragment If-Else Statement": {
    "prefix": "ifelse",
    "body": [
      "{% if ${1:condition} %}",
      "\t${2:}",
      "{% else %}",
      "\t$0",
      "{% endif %}"
    ],
    "description": "Create a fragment if-else statement"
  },
  "Fragment If-Elif-Else Statement": {
    "prefix": "ifelif",
    "body": [
      "{% if ${1:condition} %}",
      "\t${2:}",
      "{% elif ${3:condition} %}",
      "\t${4:}",
      "{% else %}",
      "\t$0",
      "{% endif %}"
    ],
    "description": "Create a fragment if-elif-else statement"
  },
  "Fragment For Loop with Index": {
    "prefix": "fori",
    "body": [
      "{% for ${1:index}, ${2:item} in enumerate(${3:items}) %}",
      "\t$0",
      "{% endfor %}"
    ],
    "description": "Create a fragment for loop with index using enumerate"
  }
}
