{
  "name": "python-fragments",
  "displayName": "Python Fragments",
  "description": "LSP support for the Python Fragments transpiler",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [
    "onLanguage:python"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "grammars": [
      {
        "path": "./syntaxes/fragments.tmLanguage.json",
        "scopeName": "source.python.fragments",
        "injectTo": [
          "source.python"
        ],
        "embeddedLanguages": {
          "meta.embedded.html.fragment": "html"
        }
      }
    ],
    "configuration": {
      "title": "Python Fragments",
      "properties": {
        "fragments.serverPath": {
          "type": "string",
          "description": "Override path to the fragments-lsp executable. By default, derived from the active Python interpreter selected in the Python extension."
        }
      }
    }
  },
  "dependencies": {
    "@vscode/python-extension": "^1.0.5",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.0.0"
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -p . --watch"
  }
}
