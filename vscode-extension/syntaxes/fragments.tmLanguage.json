{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Python Fragments",
  "scopeName": "source.python.fragments",
  "injectionSelector": "L:source.python",
  "patterns": [
    { "include": "#fragment" }
  ],
  "repository": {
    "fragment": {
      "name": "meta.fragment",
      "begin": "<>",
      "end": "</>",
      "beginCaptures": { "0": { "name": "punctuation.definition.tag.fragment" } },
      "endCaptures": { "0": { "name": "punctuation.definition.tag.fragment" } },
      "patterns": [
        { "include": "#closing-tag" },
        { "include": "#open-tag" },
        { "include": "#interpolation" }
      ]
    },
    "closing-tag": {
      "match": "(</)([a-zA-Z][a-zA-Z0-9_-]*)(>)",
      "captures": {
        "1": { "name": "punctuation.definition.tag.fragment" },
        "2": { "name": "entity.name.tag.fragment" },
        "3": { "name": "punctuation.definition.tag.fragment" }
      }
    },
    "open-tag": {
      "begin": "(<)([a-zA-Z][a-zA-Z0-9_-]*)",
      "end": "\\s*/?>",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.fragment" },
        "2": { "name": "entity.name.tag.fragment" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.tag.fragment" }
      },
      "patterns": [
        { "include": "#interpolation" },
        {
          "match": "\"[^\"]*\"",
          "name": "string.quoted.double.fragment"
        },
        {
          "match": "[a-zA-Z_][a-zA-Z0-9_-]*",
          "name": "entity.other.attribute-name.fragment"
        }
      ]
    },
    "interpolation": {
      "begin": "\\{\\{",
      "end": "\\}\\}",
      "beginCaptures": { "0": { "name": "punctuation.section.embedded.fragment" } },
      "endCaptures": { "0": { "name": "punctuation.section.embedded.fragment" } }
    }
  }
}
