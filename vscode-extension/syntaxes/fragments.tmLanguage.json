{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Python Fragments",
  "scopeName": "source.python.fragments",
  "injectionSelector": "L:source.python - (comment, string)",
  "patterns": [
    { "include": "#fragment" }
  ],
  "repository": {
    "fragment": {
      "name": "meta.fragment",
      "contentName": "meta.embedded.html.fragment",
      "begin": "<>",
      "end": "</>",
      "beginCaptures": { "0": { "name": "punctuation.definition.tag.fragment" } },
      "endCaptures": { "0": { "name": "punctuation.definition.tag.fragment" } },
      "patterns": [
        { "include": "#comment" },
        { "include": "#closing-tag" },
        { "include": "#open-tag" },
        { "include": "#interpolation" }
      ]
    },
    "comment": {
      "name": "comment.block.html",
      "begin": "<!--",
      "end": "-->",
      "beginCaptures": { "0": { "name": "punctuation.definition.comment.html" } },
      "endCaptures": { "0": { "name": "punctuation.definition.comment.html" } }
    },
    "closing-tag": {
      "match": "(</)([a-zA-Z][a-zA-Z0-9_-]*)(>)",
      "captures": {
        "1": { "name": "punctuation.definition.tag.fragment" },
        "2": { "name": "entity.name.tag.fragment" },
        "3": { "name": "punctuation.definition.tag.fragment" }
      }
    },
    "open-tag": {
      "begin": "(<)([a-zA-Z][a-zA-Z0-9_-]*)",
      "end": "\\s*/?>",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.fragment" },
        "2": { "name": "entity.name.tag.fragment" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.tag.fragment" }
      },
      "patterns": [
        { "include": "#interpolation" },
        { "include": "#alpine-attribute" },
        {
          "match": "\"[^\"]*\"",
          "name": "string.quoted.double.fragment"
        },
        {
          "match": "[a-zA-Z_][a-zA-Z0-9_-]*",
          "name": "entity.other.attribute-name.fragment"
        }
      ]
    },
    "alpine-attribute": {
      "begin": "(x-[a-zA-Z0-9_:-]*)\\s*(=)\\s*(\")",
      "end": "(\")",
      "beginCaptures": {
        "1": { "name": "entity.other.attribute-name.alpine.fragment" },
        "2": { "name": "punctuation.separator.key-value.html" },
        "3": { "name": "punctuation.definition.string.begin.html" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.string.end.html" }
      },
      "contentName": "meta.embedded.js.alpine",
      "patterns": [
        { "include": "source.js" }
      ]
    },
    "interpolation": {
      "begin": "(\\{)(\\{)",
      "end": "(\\})(\\})",
      "beginCaptures": {
        "1": { "name": "punctuation.section.embedded.fragment" },
        "2": { "name": "punctuation.section.embedded.fragment" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.section.embedded.fragment" },
        "2": { "name": "punctuation.section.embedded.fragment" }
      },
      "patterns": [
        { "include": "source.python" }
      ]
    }
  }
}
