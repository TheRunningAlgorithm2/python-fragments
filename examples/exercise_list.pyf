from examples.exercise import Exercise


def ExerciseList(exercises: list[Exercise]):
    exercise_names = [exercise.name for exercise in exercises]
    def inner():
        return <>
            <ul class="test">
                {% for exercise_name in exercise_names %}
                    <li>{{ exercise_name }}</li>
                {% endfor %}
            </ul>
        </>
    
    return inner()
