from fastapi import FastAPI

app = FastAPI()


frag ExerciseList(exercises: list[Exercise]):
    return <>
        <ul>
            {% for exercise in exercises %}
                <li>{{ exercise }}</li>
            {% endfor %}
        </ul>
    </>


@app.get("/exercise/list")
async def exercise_list(
    exercise_repo: ExerciseRepo,
    user: Annotated[User, RoutedUser(redirect=True)],
):
    return ExerciseList(exercise_repo.all(user))
